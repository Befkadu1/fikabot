{
  "name": "fikabot-site",
  "version": "1.0.0",
  "description": "FikaBot AB static marketing site (Preact + Vite + SCSS)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 8765",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && rsync -avz --delete -e \"ssh -i ~/.ssh/loopia_fikabot\" dist/ cy830c@ssh.loopia.se:~/fikabot.se/public_html/"
  },
  "dependencies": {
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.2",
    "sass": "^1.77.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
